# Keystatic GitHub OAuth Configuration
# Get these from: https://github.com/settings/developers
# OR from your GitHub Organization settings if using an Org OAuth App

KEYSTATIC_GITHUB_CLIENT_ID=your_github_oauth_app_client_id
KEYSTATIC_GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret

# Instructions:
# 1. Create a GitHub OAuth App at https://github.com/settings/developers
# 2. Set Homepage URL to: https://your-domain.vercel.app
# 3. Set Authorization callback URL to: https://your-domain.vercel.app/api/keystatic/github/oauth/callback
# 4. Copy the Client ID and generate a Client Secret
# 5. Add these as environment variables in Vercel (Settings > Environment Variables)
# 6. Make sure to set them for Production, Preview, and Development environments
